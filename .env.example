# Renomeie este arquivo para ".env" e preencha os valores.
# NUNCA suba o .env para o GitHub (já está no .gitignore).

# Token do seu bot, obtido com o @BotFather no Telegram
TELEGRAM_TOKEN=cole_seu_token_aqui

# Chave da API do Gemini, obtida em https://aistudio.google.com/apikey
GEMINI_API_KEY=cole_sua_chave_aqui

# Raio de busca (em metros) para postos e atracoes ao redor da posicao atual
SEARCH_RADIUS=15000

# Distancia (em metros) para o bot avisar que voces estao perto de um ponto planejado
PROXIMITY_ALERT=3000
